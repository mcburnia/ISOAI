{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,s)=>{const p=require('http').request({hostname:'127.0.0.1',port:5174,path:q.url,method:q.method,headers:q.headers},r=>{s.writeHead(r.statusCode,r.headers);r.pipe(s)});q.pipe(p)}).listen(5176,()=>console.log('Proxy on 5176'))"],
      "port": 5176
    }
  ]
}
